# ============================================================
# OmniFlow — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=omniflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=omniflow

# --- Security ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_MIN_64_CHARS_RANDOM_STRING

# --- CORS (comma-separated list of allowed origins) ---
CORS_ORIGINS=https://osw.conectaai.cl

# --- Frontend public API URL ---
NEXT_PUBLIC_API_URL=https://osw.conectaai.cl/api/v1

# --- n8n ---
N8N_HOST=osw.conectaai.cl

# --- URLs ---
FRONTEND_URL=https://osw.conectaai.cl
BACKEND_URL=https://osw.conectaai.cl

# --- Platform SuperAdmin (auto-created on first boot) ---
SUPERADMIN_EMAIL=corp.conectaai@gmail.com
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- n8n Internal API ---
N8N_API_SECRET=CHANGE_ME_RANDOM_SECRET

# --- Email (Resend — for password reset emails) ---
# Get your key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxx

# --- Mercado Pago ---
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# --- WhatsApp Business ---
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_RANDOM_TOKEN
