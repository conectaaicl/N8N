# ============================================================
# OmniFlow — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=omniflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=omniflow

# --- Security ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_MIN_64_CHARS_RANDOM_STRING

# --- CORS (comma-separated list of allowed origins) ---
CORS_ORIGINS=https://osw.conectaai.cl

# --- Frontend public API URL ---
NEXT_PUBLIC_API_URL=https://osw.conectaai.cl/api/v1

# --- n8n ---
N8N_HOST=osw.conectaai.cl

# --- WhatsApp Business ---
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_RANDOM_TOKEN
# WHATSAPP_PHONE_ID=your_phone_id
# WHATSAPP_ACCESS_TOKEN=your_access_token
